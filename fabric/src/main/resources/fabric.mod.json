{
    "schemaVersion": 1,
    "id": "betterbrightness",
    "version": "${version}",
    "name": "Better Brightness Setup",
    "description": "Improves Minecraft's brightness setup and adds a first-launch calibration screen that previews how bright the game will actually look.",
    "authors": [
        "fimkov"
    ],
    "license": "MIT",
    "icon": "icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "io.github.fimkov.betterbrightness.fabric.BetterBrightnessFabric"
        ],
        "modmenu": [
            "io.github.fimkov.betterbrightness.fabric.BetterBrightnessModMenu"
        ]
    },
    "mixins": [
        "betterbrightness.mixins.json",
        "betterbrightness.sodium.mixins.json"
    ],
    "accessWidener": "betterbrightness.accesswidener",
    "depends": {
        "fabricloader": ">=0.16.0",
        "minecraft": "~1.20.1",
        "java": ">=17",
        "architectury": ">=9.2.0",
        "fabric-api": "*",
        "cloth-config": ">=11.1.0"
    },
    "suggests": {
        "modmenu": "*",
        "sodium": "*"
    }
}
